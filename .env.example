# Configuration d'environnement pour Teraka
# Copier ce fichier en .env et adapter les valeurs selon votre environnement

# ============================================
# ENVIRONNEMENT
# ============================================
ENV=development
DEBUG=True

# ============================================
# DJANGO
# ============================================
DJANGO_SECRET_KEY=your-super-secret-key-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,teraka-api.herokuapp.com,teraka-api.onrender.com

# ============================================
# BASE DE DONNÉES
# ============================================
DATABASE_URL=postgres://postgres:ad,in@localhost:5432/teraka
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teraka
DB_USER=postgres
DB_PASSWORD=ad,in

# ============================================
# POSTGREST
# ============================================
POSTGREST_HOST=127.0.0.1
POSTGREST_PORT=3000
POSTGREST_JWT_SECRET=your-super-secret-key-change-me-in-production
POSTGREST_DB_URI=postgres://postgres:ad,in@localhost:5432/teraka
POSTGREST_DB_SCHEMA=public
POSTGREST_DB_ANON_ROLE=anon

# ============================================
# SERVEURS
# ============================================
DJANGO_PORT=8000
DJANGO_WORKERS=4
DJANGO_TIMEOUT=120

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ============================================
# SMTP (Email)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================
# SÉCURITÉ (À activer en production)
# ============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/teraka/django.log
