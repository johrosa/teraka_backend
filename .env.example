# Configuration d'environnement pour Teraka
# Environment Configuration Template
# Copier ce fichier en .env et adapter les valeurs selon votre environnement
# Copy to .env and customize for your environment
# WARNING: Ne pas commiter .env avec des secrets réels! / Never commit .env with real secrets!

# ============================================
# ENVIRONNEMENT / ENVIRONMENT
# ============================================
ENV=development
DEBUG=True

# ============================================
# DJANGO (Backend API)
# ============================================
DJANGO_SECRET_KEY=your-super-secret-key-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,teraka-api.herokuapp.com,teraka-api.onrender.com
DJANGO_PORT=8000
DJANGO_WORKERS=4
DJANGO_TIMEOUT=120

# ============================================
# BASE DE DONNÉES / DATABASE
# ============================================
# Full connection string (overrides DB_* vars if set)
DATABASE_URL=postgres://postgres:admin@postgres:5432/teraka

# Or use individual variables:
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_HOST=postgres
DB_PORT=5432
DB_NAME=teraka
DB_USER=postgres
DB_PASSWORD=admin

# ============================================
# POSTGREST (REST API Layer)
# ============================================
POSTGREST_HOST=0.0.0.0
POSTGREST_PORT=3000
POSTGREST_JWT_SECRET=your-super-secret-key-change-me-in-production
POSTGREST_DB_URI=postgres://postgres:admin@postgres:5432/teraka
POSTGREST_DB_SCHEMA=public
POSTGREST_DB_ANON_ROLE=web_anon
POSTGREST_MAX_ROWS=1000

# ============================================
# PATHS / CHEMINS (Optional Override)
# ============================================
# Leave empty to use defaults / Laisser vide pour utiliser les défauts

# Project root directory / Répertoire racine du projet
# TERAKA_PROJECT_DIR=/opt/teraka

# PostgREST binary path / Chemin du binaire PostgREST
# POSTGREST_BIN=/usr/local/bin/postgrest

# PostgREST config file / Fichier de config PostgREST
# POSTGREST_CONF_PATH=/etc/postgrest/postgrest.conf

# ============================================
# CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ============================================
# API Configuration
# ============================================
API_TIMEOUT=30

# ============================================
# SMTP (Email)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================
# SÉCURITÉ / SECURITY (Activate in production)
# ============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/teraka/django.log

# ============================================
# DOCKER / COMPOSE
# ============================================
COMPOSE_PROJECT_NAME=teraka
COMPOSE_HTTP_TIMEOUT=60
DEVELOPMENT_MODE=0
